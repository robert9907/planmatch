    "@twilio/voice-sdk": "^2.18.2",
    "@vercel/blob": "^2.3.3",
    "@vercel/node": "^5.7.10",
    "csv-parse": "^5.5.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "pg": "^8.13.0",
    "pg-copy-streams": "^6.0.6",
