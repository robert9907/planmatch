{
  "_meta": {
    "purpose": "CMS ground-truth parity check for the agent's /api/plans output.",
    "source_of_truth": "medicare.gov Plan Finder (when hand-verified) or production snapshot (when verifiedOn carries the 'production-snapshot' label).",
    "tolerances": {
      "premium": 1,
      "copay": 5,
      "moop": 50,
      "coinsurance": 2,
      "allowance": 25
    },
    "rules": [
      "All expected.* fields start null on a fresh fixture entry. The validator skips null fields so an unverified entry passes trivially.",
      "Bump verifiedOn each time the row is reconciled against the source of truth (medicare.gov or production-snapshot).",
      "When verifiedOn carries 'production-snapshot YYYY-MM-DD' the fixture pinned the agent's then-current values; treat the resulting harness as drift detection, NOT CMS parity.",
      "When verifiedOn carries an ISO date alone the fixture was hand-verified against medicare.gov."
    ],
    "field_taxonomy": {
      "plan_top_level": [
        "premium",
        "moop_in_network",
